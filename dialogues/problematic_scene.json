    "n_dead_end1": {
      "node_id": "n_dead_end1",
      "node_type": "dialogue",
      "speaker": "主角",
      "text": "这个房间...我好像在哪里见过。",
      "fear_intensity": "medium",
      "dialogue_type": "tension"
    },
    "n_call": {
      "node_id": "n_call",
      "node_type": "dialogue",
      "speaker": "主角",
      "text": "有人吗？救命！",
      "next_node": "n_response",
