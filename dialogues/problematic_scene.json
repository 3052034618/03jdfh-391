    },
    "n_response": {
      "node_id": "n_response",
      "node_type": "dialogue",
      "speaker": "门外",
      "text": "别喊了。你逃不掉的。",
      "next_node": "n_conflict",
      "fear_intensity": "high",
      "dialogue_type": "tension"
    },
    "n_conflict": {
      "node_id": "n_conflict",
      "node_type": "narration",
      "text": "你想起了一切。但你什么都不记得了。",
      "next_node": "n_ending1",
      "conditions": [
        {
          "variable": "has_memory",
