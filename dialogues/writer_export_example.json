    "n_dead_end_run": {
      "node_id": "n_dead_end_run",
      "node_type": "dialogue",
      "speaker": "主角",
      "text": "不...不！门被锁住了！我没有钥匙！",
      "fear_intensity": "high",
      "dialogue_type": "tension"
    },
    "n_ending_hide": {
      "node_id": "n_ending_hide",
      "node_type": "ending",
      "text": "Bad Ending - 躲藏者。门被缓缓推开。你屏住呼吸，但它已经闻到了你的味道...",
      "fear_intensity": "high",
      "dialogue_type": "tension"
    },
    "n_ending_face": {
      "node_id": "n_ending_face",
      "node_type": "ending",
      "text": "Bad Ending - 重逢。陈博士发出模糊的声音：「你...终于...来看我了...」他张开双臂抱住了你，永远地。",
      "fear_intensity": "high",
      "dialogue_type": "tension"
    },
    "n_ending_truth": {
      "node_id": "n_ending_truth",
      "node_type": "ending",
      "text": "True Ending - 赎罪。你终于想起了一切。现在，你必须做出选择：是结束这一切，还是继续陈博士未完成的实验...",
      "fear_intensity": "medium",
      "dialogue_type": "buffer"
    }
  }
