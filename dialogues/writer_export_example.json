    "n_enter_lab": {
      "node_id": "n_enter_lab",
      "node_type": "narration",
      "text": "实验室内部比你想象的要大得多。培养皿中漂浮着...是人的器官？墙上的屏幕显示着「实验体-007：苏醒」。",
      "next_node": "n_lab_choice",
      "fear_intensity": "high",
      "dialogue_type": "tension",
      "set_variables": {
        "in_lab": true,
        "found_photo": true
      }
    },
    "n_lab_choice": {
      "node_id": "n_lab_choice",
      "node_type": "choice",
      "text": "你注意到实验室中央有一台主控制台，旁边的玻璃柜里放着一份实验报告。你决定：",
      "choices": [
        {
          "choice_id": "c_console",
          "text": "先查看控制台",
          "next_node": "n_check_console"
        },
        {
          "choice_id": "c_report",
          "text": "先看实验报告",
          "next_node": "n_read_report"
        }
      ],
      "fear_intensity": "medium",
      "dialogue_type": "tension",
      "conditions": [
        {
          "variable": "has_access_card",
          "operator": "==",
          "value": true,
